APP_NAME=FastAPI Backend Template
APP_ENV=local
DEBUG=true
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://app_user:app_password@postgres.example.com:5432/app_db
# PostgreSQL:
# DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/app
# MySQL 8.0:
# DATABASE_URL=mysql+pymysql://app:app@localhost:3306/app?charset=utf8mb4
SECRET_KEY=change-this-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
REDIS_URL=redis://localhost:6379/0
REDIS_PREFIX=backend
REDIS_DEFAULT_TTL_SECONDS=300
